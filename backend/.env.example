# ========================
# dclickora Backend
# ========================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clickora?schema=public"
# Railway: no serviço da API, usa a variável injetada pelo Postgres (referência ao plugin).
# URLs públicas/proxy costumam precisar de ?sslmode=require (ou &sslmode=require)

# Login com Google (OAuth 2.0 — tipo "Aplicação Web"; mesmo ID no frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_OAUTH_CLIENT_ID=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
# Docker/Railway (start-production.sh): o seed NÃO corre por defeito no arranque (evita 502).
# Primeiro deploy com BD vazia: RUN_SEED_ON_START=true uma vez, redeploy, depois remove.
# Ou: SKIP_DB_SEED=true para forçar skip explícito.

# Frontend URL (CORS). Vários domínios: separar por vírgula. Só origin (sem path). www e apex são expandidos a partir de cada entrada.
# Produção: incluir site real, ex.: https://www.dclickora.com,https://dclickora.com — obrigatório se o browser chama a API noutro host (Railway).
# Incluir a porta do Vite em uso (8080 no projeto; 5173 é o default do Vite). Várias: separar por vírgula.
FRONTEND_URL="http://localhost:8080,http://localhost:5173"
# Opcional: origens extra (lista explícita).
# CORS_ALLOWED_ORIGINS=""

# Hotmart Webhook
# Mesmo segredo da aba Autenticação (hottok). Webhook 2.0 também pode usar HMAC (x-hotmart-signature);
# o corpo bruto é guardado em req.rawBody — ver webhook.controller.ts
HOTMART_WEBHOOK_TOKEN=""
# Opcional: se a Hotmart usar segredo de assinatura diferente do hottok, define aqui (senão usa HOTMART_WEBHOOK_TOKEN)
# HOTMART_WEBHOOK_SECRET=""
# Map offer/product code -> plan type (free_trial|monthly|annual)
# Example: {"OFFER123":"monthly","OFFER999":"annual"}
HOTMART_PLAN_MAP="{}"
# Fallback plan type when code is not in map
HOTMART_DEFAULT_PLAN_TYPE="monthly"
# Checkout externo (Angola / sem Stripe): página de vendas Hotmart — usado em POST /plans/subscribe para planos pagos
# HOTMART_PRODUCT_URL="https://hotmart.com/pt-br/your-product"
# Opcional: URL por id de plano interno (plan_monthly, plan_annual, …)
# HOTMART_PLAN_CHECKOUT_URLS={"plan_monthly":"https://...","plan_annual":"https://..."}
# Alias:
# PUBLIC_CHECKOUT_URL=""

# Google Ads — Conversion Upload API (servidor). OAuth Web app + developer token na Google Ads API Center.
# O refresh token pode ficar só aqui (todas as contas) ou por utilizador no painel (Tracking).
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_REFRESH_TOKEN=""
# Opcional (legado): não é usado no envio por utilizador — MCC vai no painel Tracking → Google Ads.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""

# Google Ads postback token (optional but recommended)
GOOGLE_POSTBACK_TOKEN=""
# Microsoft Ads postback token (optional; fallback = GOOGLE_POSTBACK_TOKEN)
MICROSOFT_POSTBACK_TOKEN=""
# URL pública da API (com /api no fim). Em produção use HTTPS e o domínio que o browser vê (ex.: site na Vercel).
# Ex.: https://www.dclickora.com/api — webhooks e URLs em Plataformas ficam com protocolo e host corretos.
API_PUBLIC_URL="http://localhost:3001/api"

# Web Push (notificações no browser / telemóvel em Integrações). Gere com: npx web-push generate-vapid-keys
# VAPID_SUBJECT é normalmente um mailto: (contacto visível para o serviço de push).
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:support@dclickora.com"

# SMTP — alertas de venda (Plataformas / webhook de afiliados). Sem isto, o teste de e-mail fica indisponível.
# SMTP_HOST="smtp.exemplo.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="dclickora <noreply@dclickora.com>"
