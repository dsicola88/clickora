{
  "name": "dclickora-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "start:prod": "prisma migrate deploy && node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate:resolve-rolled-back:meta-capi": "prisma migrate resolve --rolled-back 20260417130000_meta_capi_integration",
    "db:migrate:resolve-applied:meta-capi": "prisma migrate resolve --applied 20260417130000_meta_capi_integration",
    "db:migrate:resolve-rolled-back:auto-blacklist": "prisma migrate resolve --rolled-back 20260422120000_user_auto_blacklist_click_limit",
    "db:migrate:resolve-applied:auto-blacklist": "prisma migrate resolve --applied 20260422120000_user_auto_blacklist_click_limit",
    "db:migrate:fix-railway-p3009:auto-blacklist": "sh scripts/fix-p3009-auto-blacklist-railway-env.sh",
    "db:migrate:resolve-rolled-back:auto-blacklist-railway-typo": "prisma migrate resolve --rolled-back 20240422120000_user_auto_blacklist_click_limit",
    "db:migrate:resolve-rolled-back:railway-typo-meta": "prisma migrate resolve --rolled-back 20240417130000_meta_copi_integration",
    "db:migrate:fix-railway-p3009-typo": "sh scripts/fix-railway-p3009-typo.sh",
    "db:migrate:railway-p3009": "sh scripts/migrate-railway-p3009-from-railway-env.sh",
    "db:railway:check": "sh scripts/railway-db-check-connection.sh",
    "test:custom-domain": "tsx scripts/test-custom-domain-flow.ts",
    "test:affiliate-dns": "tsx scripts/test-custom-domain-flow.ts",
    "test:presell-multitenant": "tsx scripts/test-presell-multitenant-flow.ts",
    "test:unit": "node --import tsx --test src/lib/routingRules/evaluate.test.ts",
    "test:paid": "node --import tsx --test src/paid/tiktok-campaign-plan.objectives.test.ts src/paid/guardrails-eval.test.ts src/paid/google-campaign-bidding.test.ts src/paid/optimizer/rules.engine.test.ts src/paid/optimizer/idempotency.unit.test.ts src/paid/optimizer/optimizer.service.test.ts",
    "paid:optimizer:once": "tsx scripts/run-paid-optimizer-once.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.4.1",
    "geoip-lite": "^2.0.1",
    "google-ads-api": "^23.0.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "playwright": "^1.50.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
