// ===========================================
// Clickora Backend — Prisma Schema
// Compatible with frontend src/types/api.ts
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// Enums
// ========================

enum AppRole {
  super_admin
  admin
  moderator
  user
}

enum PlanType {
  free_trial
  monthly
  quarterly
  annual
}

enum PresellStatus {
  draft
  published
  paused
  archived
}

enum EventType {
  click
  impression
  conversion
  lead
  sale
  pageview
}

/** Distribuição de cliques entre vários destinos (estilo rotador ClickMagick). */
enum TrafficRotatorMode {
  random
  weighted
  sequential
  fill_order
}

/** Filtro por tipo de dispositivo por destino do rotador. */
enum RotatorDeviceRule {
  all
  mobile
  desktop
}

enum SubscriptionStatus {
  active
  canceled
  expired
  suspended
}

enum CustomDomainStatus {
  pending
  verified
}

/** Papel dentro de um workspace (equipa). */
enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

// ========================
// Models
// ========================

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   // bcrypt hash
  fullName    String?  @map("full_name")
  /** Google OAuth `sub` — opcional; login Google usa o mesmo e-mail da conta. */
  googleId    String?  @unique @map("google_id")
  avatarUrl   String?  @map("avatar_url")
  /** E-mail opcional para alertas de venda (postback de afiliados). Se vazio, usa `email`. */
  saleNotifyEmail String? @map("sale_notify_email")
  /** OAuth refresh token da conta Google Ads (opcional se usar só variáveis de ambiente globais). */
  googleAdsRefreshToken String?  @map("google_ads_refresh_token") @db.Text
  googleAdsEnabled           Boolean  @default(false) @map("google_ads_enabled")
  /** Customer ID numérico (sem hífenes), ex. 1234567890 */
  googleAdsCustomerId        String?  @map("google_ads_customer_id")
  /** ID da ação de conversão em Ferramentas → Conversões (número). */
  googleAdsConversionActionId String? @map("google_ads_conversion_action_id")
  /** Conta gestora (MCC) se aplicável, só dígitos. */
  googleAdsLoginCustomerId   String?  @map("google_ads_login_customer_id")
  /** Meta Conversions API (Pixel): envio server-side de Purchase após postback aprovado. */
  metaCapiEnabled        Boolean @default(false) @map("meta_capi_enabled")
  /** ID numérico do Pixel (Gestor de eventos / Pixel do Facebook). */
  metaPixelId            String? @map("meta_pixel_id")
  /** Token de acesso da API de Conversões (não é o Pixel client-side). */
  metaAccessToken        String? @map("meta_access_token") @db.Text
  /** Opcional: código de teste do Gestor de eventos (validação antes de produção). */
  metaCapiTestEventCode  String? @map("meta_capi_test_event_code")
  /** TikTok Events API (Pixel): envio server-side de Purchase após postback aprovado (com ttclid no clique). */
  tiktokEventsEnabled        Boolean @default(false) @map("tiktok_events_enabled")
  /** Código do Pixel (Events Manager) — o mesmo usado no browser. */
  tiktokPixelId              String? @map("tiktok_pixel_id")
  /** Token da Events API (TikTok Ads Manager → Pixel → Settings). Cifrado com ENCRYPTION_KEY. */
  tiktokEventsAccessToken    String? @map("tiktok_events_access_token") @db.Text
  /** Opcional: Test Events (diagnóstico). */
  tiktokEventsTestEventCode  String? @map("tiktok_events_test_event_code")
  /** Bot Telegram (@BotFather). Não expor em APIs públicas. */
  telegramBotToken String? @map("telegram_bot_token") @db.Text
  telegramChatId   String? @map("telegram_chat_id")
  telegramNotifySale Boolean @default(true) @map("telegram_notify_sale")
  telegramNotifyPostbackError Boolean @default(true) @map("telegram_notify_postback_error")
  telegramNotifyClick         Boolean @default(false) @map("telegram_notify_click")
  /** Opt-in: recusa eventos de tracking com User-Agent vazio (reduz tráfego «anónimo»/scripts). */
  blockEmptyUserAgent Boolean @default(false) @map("block_empty_user_agent")
  /** Opt-in: bloqueia cliques/impressões identificados como bot (UA). */
  blockBotClicks      Boolean @default(false) @map("block_bot_clicks")
  /**
   * 0 = desligado. N > 0: máximo de eventos `click` rastreados por IPv4 neste IP na janela;
   * ao exceder, o pedido seguinte recebe 403 e o IP é acrescentado à blacklist.
   */
  autoBlacklistClickThreshold     Int @default(0) @map("auto_blacklist_click_threshold")
  /** Janela deslizante em horas para contar cliques (1–168; por defeito 24). */
  autoBlacklistClickWindowHours   Int @default(24) @map("auto_blacklist_click_window_hours")
  workspaceId String   @default(uuid()) @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  roles          UserRole[]
  presellPages   PresellPage[]
  trackingEvents TrackingEvent[]
  postbackLogs   PostbackLog[]
  subscription   Subscription?
  conversions    Conversion[]
  webPushSubscriptions WebPushSubscription[]
  customDomains        CustomDomain[]
  whitelistedIps WhitelistedIp[]
  trafficRotators      TrafficRotator[]
  ownedWorkspace       Workspace?           @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]

  /** Módulo anúncios (ex-Dpiloto) — dados escopados ao dono da conta (tenant). */
  paidAdsProjects              PaidAdsProject[]
  paidAdsChangeRequestsReq     PaidAdsChangeRequest[] @relation("PaidChangeRequestedBy")
  paidAdsChangeRequestsRev     PaidAdsChangeRequest[] @relation("PaidChangeReviewedBy")
  paidAdsAiRunsAsAuthor       PaidAdsAiRun[]         @relation("PaidAdsAiRunAuthor")

  @@map("users")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(200)
  ownerUserId String   @unique @map("owner_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User                  @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  auditLog WorkspaceAuditLog[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  /** Permissões extra (ex.: [\"integrations:write\"]); null = só o papel base. */
  permissions Json?       @map("permissions")
  createdAt   DateTime      @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceAuditLog {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  actorUserId  String   @map("actor_user_id")
  action       String   @db.VarChar(160)
  resourceType String?  @map("resource_type") @db.VarChar(80)
  resourceId   String?  @map("resource_id") @db.VarChar(80)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("workspace_audit_logs")
}

/** Vários domínios por conta; `is_default` indica o URL base quando a presell não escolhe outro. */
model CustomDomain {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  /** Hostname normalizado em minúsculas, ex.: www.exemplo.com */
  hostname            String             @unique
  verificationToken   String             @map("verification_token") @db.VarChar(128)
  status              CustomDomainStatus @default(pending)
  verifiedAt          DateTime?          @map("verified_at")
  isDefault           Boolean            @default(false) @map("is_default")
  /** Domínio registado na API Vercel (projeto do site) — verificação via Vercel + CNAME. */
  vercelDomainRegistered Boolean         @default(false) @map("vercel_domain_registered")
  /** Último desafio de verificação devolvido pela Vercel (TXT, etc.) para mostrar na UI. */
  vercelVerificationJson Json?          @map("vercel_verification_json")
  /** Presell publicada que abre em `https://hostname/`; nulo = usar a mais recentemente atualizada. Vários domínios podem usar a mesma presell na raiz. */
  rootPresellId String? @map("root_presell_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rootPresell  PresellPage?  @relation("DomainRootPresell", fields: [rootPresellId], references: [id], onDelete: SetNull)
  presellPages PresellPage[] @relation("DomainPresellLinks")

  @@index([userId])
  @@index([hostname])
  @@map("custom_domains")
}

/** Subscrição Web Push (navegador) para alertas de conversão no telemóvel/desktop. */
model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  /** URL única do serviço de push do browser (ex.: FCM). */
  endpoint  String   @unique @db.Text
  p256dh    String   @map("p256dh") @db.Text
  auth      String   @db.Text
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("web_push_subscriptions")
}

model UserRole {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  role   AppRole @default(user)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

/** Catálogo global de planos (sem tenant — partilhado por todas as contas). */
model Plan {
  id               String   @id @default(uuid())
  name             String
  type             PlanType
  priceCents       Int      @default(0) @map("price_cents")
  maxPresellPages  Int?     @map("max_presell_pages")
  maxClicksPerMonth Int?    @map("max_clicks_per_month")
  hasBranding      Boolean  @default(true) @map("has_branding")
  /** Postback HTTP (Integrações → Plataformas): activo por plano; admin pode alterar. */
  affiliateWebhookEnabled Boolean @default(false) @map("affiliate_webhook_enabled")
  /** Dpiloto — criador/automação de anúncios (módulo premium; Pro e Starter = false por defeito). */
  dpilotAdsEnabled Boolean @default(false) @map("dpilot_ads_enabled")
  /** Domínios personalizados permitidos (0 = só HTML/dclickora; anual típico = 2). */
  maxCustomDomains Int      @default(0) @map("max_custom_domains")
  features         Json     @default("[]")
  /** Texto do botão do cartão (opcional). Se vazio, usam-se as etiquetas globais (começar grátis / upgrade / plano atual). */
  ctaLabel         String?  @map("cta_label") @db.VarChar(160)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String             @unique @map("user_id")
  planId    String             @map("plan_id")
  status    SubscriptionStatus @default(active)
  startsAt  DateTime           @default(now()) @map("starts_at")
  endsAt    DateTime?          @map("ends_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model PresellPage {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  title       String
  slug        String
  /// Modelo da página: cookies, vsl, tsl, desconto, …, ou `builder` (editor visual; ver `content.pageDocument`).
  type        String        @default("cookies")
  category    String?
  language    String?       @default("pt")
  content     Json?
  videoUrl    String?       @map("video_url")
  settings    Json?
  tracking    Json?
  status      PresellStatus @default(draft)
  clicks      Int           @default(0)
  impressions Int           @default(0)
  conversions Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  /** Domínio público preferido para links desta presell; nulo = usar domínio padrão da conta. */
  customDomainId String?  @map("custom_domain_id")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customDomain   CustomDomain?   @relation("DomainPresellLinks", fields: [customDomainId], references: [id], onDelete: SetNull)
  /** Domínios personalizados que abrem esta presell em `https://hostname/` (pode ser mais do que um). */
  rootForDomains CustomDomain[] @relation("DomainRootPresell")
  trackingEvents TrackingEvent[]
  postbackLogs PostbackLog[]
  linkedConversions Conversion[]
  /** Presells usadas como contexto de relatório/conversão em rotadores de tráfego. */
  trafficRotatorsAsContext TrafficRotator[] @relation("RotatorContextPresell")

  @@unique([userId, slug])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([customDomainId])
  @@map("presell_pages")
}

model PostbackLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  presellPageId String?  @map("presell_page_id")
  platform     String
  status       String
  message      String?
  payload      Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  presellPage PresellPage? @relation(fields: [presellPageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([platform, createdAt])
  @@map("postback_logs")
}

model TrackingEvent {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  presellPageId String?   @map("presell_page_id")
  eventType     EventType @map("event_type")
  source        String?
  medium        String?
  campaign      String?
  referrer      String?
  country       String?
  device        String?
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  presellPage PresellPage? @relation(fields: [presellPageId], references: [id], onDelete: SetNull)
  conversion  Conversion?

  @@index([userId])
  @@index([presellPageId])
  @@index([eventType])
  @@index([createdAt])
  @@index([userId, eventType, createdAt])
  @@map("tracking_events")
}

/**
 * Rotador de tráfego: um URL público reparte cliques entre vários destinos (A/B, sequência, preenchimento).
 * O `contextPresellId` liga conversões por postback ao mesmo fluxo que uma presell publicada.
 */
model TrafficRotator {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  name             String
  /** Identificador curto único por conta (etiqueta interna / futuros links curtos). */
  slug             String
  mode             TrafficRotatorMode
  backupUrl        String?            @map("backup_url") @db.Text
  contextPresellId String             @map("context_presell_id")
  /** Cursor para modo `sequential` (round-robin entre destinos elegíveis). */
  sequenceCursor   Int                @default(0) @map("sequence_cursor")
  /** Se definido, o visitante tem de passar `?access_code=` igual. */
  accessCode       String?            @map("access_code") @db.VarChar(256)
  /**
   * Política de regras avançadas (JSON versionado): geo, dispositivo, janelas UTC, caps globais,
   * bloqueio, redirecionamento forçado ou uso do backup antes da escolha de braços.
   */
  rulesPolicy      Json?              @map("rules_policy")
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contextPresell PresellPage          @relation("RotatorContextPresell", fields: [contextPresellId], references: [id], onDelete: Restrict)
  arms           TrafficRotatorArm[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([contextPresellId])
  @@map("traffic_rotators")
}

model TrafficRotatorArm {
  id              String            @id @default(uuid())
  rotatorId       String            @map("rotator_id")
  destinationUrl  String            @map("destination_url") @db.Text
  label           String?
  orderIndex      Int               @map("order_index")
  weight          Int               @default(100)
  maxClicks       Int?              @map("max_clicks")
  clicksDelivered Int               @default(0) @map("clicks_delivered")
  /** JSON: lista de códigos ISO2 permitidos; null/vazio = qualquer país (sujeito a `countriesDeny`). */
  countriesAllow  Json?             @map("countries_allow")
  countriesDeny   Json?             @map("countries_deny")
  deviceRule      RotatorDeviceRule @default(all) @map("device_rule")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  rotator TrafficRotator @relation(fields: [rotatorId], references: [id], onDelete: Cascade)

  @@index([rotatorId, orderIndex])
  @@map("traffic_rotator_arms")
}

/** Conversão ligada a um clique (ex.: postback de afiliado com clickora_click_id). */
model Conversion {
  id        String   @id @default(uuid())
  clickId   String   @unique @map("click_id")
  userId    String   @map("user_id")
  presellId String   @map("presell_id")
  campaign  String?
  amount    Decimal? @db.Decimal(14, 4)
  currency  String?  @default("USD")
  status    String   @default("approved")
  metadata  Json?
  /** sent | failed | skipped_no_gclid | skipped_disabled | skipped_no_config | skipped_pending */
  googleAdsSync       String?   @map("google_ads_sync")
  googleAdsSyncedAt   DateTime? @map("google_ads_synced_at")
  googleAdsSyncDetail Json?     @map("google_ads_sync_detail")
  /** sent | failed | skipped_no_fbclid | skipped_disabled | skipped_no_config | skipped_pending */
  metaCapiSync       String?   @map("meta_capi_sync")
  metaCapiSyncedAt   DateTime? @map("meta_capi_synced_at")
  metaCapiSyncDetail Json?     @map("meta_capi_sync_detail")
  /** sent | failed | skipped_no_ttclid | skipped_disabled | skipped_no_config | skipped_pending */
  tiktokEventsSync       String?   @map("tiktok_events_sync")
  tiktokEventsSyncedAt   DateTime? @map("tiktok_events_synced_at")
  tiktokEventsSyncDetail Json?     @map("tiktok_events_sync_detail")
  createdAt DateTime @default(now()) @map("created_at")

  click TrackingEvent @relation(fields: [clickId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  presell PresellPage   @relation(fields: [presellId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([presellId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("conversions")
}

model BlacklistedIp {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ipAddress String   @map("ip_address")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, ipAddress])
  @@index([userId])
  @@map("blacklisted_ips")
}

/**
 * Se existir pelo menos um IP na whitelist da conta, apenas esses IPv4 contam tracking (modo restrito).
 * Lista vazio = desligado; combina com blacklist (bloqueio continua a prevalecer).
 */
model WhitelistedIp {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ipAddress String   @map("ip_address")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipAddress])
  @@index([userId])
  @@map("whitelisted_ips")
}

/** Marca global da instalação (ex.: favicon). Uma linha id "default"; não é por assinante. */
model SiteBranding {
  id          String   @id @default("default")
  faviconExt  String?  @map("favicon_ext")
  faviconMime String?  @map("favicon_mime")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_branding")
}

/** Conteúdo da landing pública /plans (hero, textos, imagem) — uma linha id "default". */
model PlansLandingConfig {
  id            String   @id @default("default")
  badgeText     String?  @map("badge_text")
  heroTitle     String   @default("Escolha seu plano") @map("hero_title")
  heroSubtitle  String?  @map("hero_subtitle") @db.Text
  heroImageExt  String?  @map("hero_image_ext")
  heroImageMime String?  @map("hero_image_mime")
  introText     String?  @map("intro_text") @db.Text
  footerText    String?  @map("footer_text") @db.Text

  /// sans | serif | mono
  heroFont         String @default("sans") @map("hero_font")
  /// left | center | right
  heroTextAlign    String @default("left") @map("hero_text_align")
  /// sm … 5xl (título do hero)
  heroTitleSize    String @default("3xl") @map("hero_title_size")
  /// normal | medium | semibold | bold | extrabold
  heroTitleWeight  String @default("bold") @map("hero_title_weight")
  /// xs | sm | base | lg | xl (subtítulo)
  heroSubtitleSize String @default("base") @map("hero_subtitle_size")

  introFont       String @default("sans") @map("intro_font")
  introTextAlign  String @default("left") @map("intro_text_align")
  introTextSize   String @default("base") @map("intro_text_size")

  footerFont      String @default("sans") @map("footer_font")
  footerTextAlign String @default("center") @map("footer_text_align")
  footerTextSize  String @default("sm") @map("footer_text_size")

  /** Etiquetas da grelha de planos (moeda, secções, botões). Merge com defaults no servidor. */
  planDisplayLabels Json? @map("plan_display_labels")

  /** Efeitos do hero: overlay, zoom, parallax, CTA, animação de entrada — merge com defaults no servidor. */
  heroVisual Json? @map("hero_visual")

  /** Tema visual, FAQ, stats, cartões de destaque — merge com defaults no servidor. */
  landingExtras Json? @map("landing_extras")

  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("plans_landing_config")
}

// ---------------------------------------------------------------------------
// Paid Ads (ex-Dpiloto) — monólito: mesmo Postgres e User.id = tenant (dono)
// (organizationId antigo = userId do dono da subscrição / workspace)
// ---------------------------------------------------------------------------

enum PaidAdsProjectMode {
  copilot
  autopilot
}

enum PaidAdsConnectionStatus {
  disconnected
  connected
  error
}

enum PaidAdsPlatform {
  google_ads
  meta_ads
  tiktok_ads
}

enum PaidAdsCampaignStatus {
  draft
  pending_publish
  live
  paused
  archived
  error
}

enum PaidAdsEntityStatus {
  draft
  pending_publish
  live
  paused
  archived
  error
}

enum PaidAdsMatchType {
  exact
  phrase
  broad
}

enum PaidAdsChangeRequestType {
  create_campaign
  update_budget
  add_keywords
  publish_rsa
  pause_entity
  meta_create_campaign
  meta_update_budget
  meta_publish_creative
  meta_pause_entity
  tiktok_create_campaign
  tiktok_update_budget
  tiktok_pause_entity
}

enum PaidAdsChangeRequestStatus {
  pending
  approved
  rejected
  applied
  failed
}

enum PaidAdsAiFeature {
  keyword_plan
  rsa_generation
  campaign_plan
}

enum PaidAdsAiRunStatus {
  pending
  success
  error
}

enum PaidAdsMetaCta {
  learn_more
  shop_now
  sign_up
  contact_us
  book_now
  download
  get_quote
  subscribe
}

model PaidAdsProject {
  id         String            @id @default(uuid())
  /// Dono dos dados = tenant (mesmo `tenantUserId` no JWT)
  userId     String            @map("user_id")
  name       String
  websiteUrl String?           @map("website_url")
  paidMode   PaidAdsProjectMode @default(copilot) @map("paid_mode")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleAdsConnection PaidAdsGoogleAdsConnection?
  metaConnection      PaidAdsMetaConnection?
  tiktokConnection    PaidAdsTikTokConnection?
  paidCampaigns       PaidAdsCampaign[]
  paidGuardrails      PaidAdsGuardrails?
  paidChangeRequests  PaidAdsChangeRequest[]
  aiRuns                  PaidAdsAiRun[]
  metaInsights            PaidAdsMetaInsight[]
  paidOptimizerDecisions  PaidAdsOptimizerDecision[]

  @@index([userId])
  @@map("paid_ads_projects")
}

model PaidAdsGoogleAdsConnection {
  id               String                 @id @default(uuid())
  userId           String                 @map("user_id")
  projectId        String                 @unique @map("project_id")
  googleCustomerId String?                @map("google_customer_id")
  accountName      String?                @map("account_name")
  status           PaidAdsConnectionStatus @default(disconnected)
  tokenRef         String?                @map("token_ref")
  lastSyncAt       DateTime?              @map("last_sync_at")
  errorMessage     String?                @map("error_message")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  project PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("paid_ads_google_ads_connections")
}

model PaidAdsMetaConnection {
  id             String                 @id @default(uuid())
  userId         String                 @map("user_id")
  projectId      String                 @unique @map("project_id")
  adAccountId    String?                @map("ad_account_id")
  businessId     String?                @map("business_id")
  accountName    String?                @map("account_name")
  status         PaidAdsConnectionStatus @default(disconnected)
  tokenRef       String?                @map("token_ref")
  lastSyncAt     DateTime?              @map("last_sync_at")
  errorMessage   String?                @map("error_message")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  project PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("paid_ads_meta_connections")
}

model PaidAdsTikTokConnection {
  id              String                 @id @default(uuid())
  userId          String                 @map("user_id")
  projectId       String                 @unique @map("project_id")
  advertiserId    String?                @map("advertiser_id")
  accountName     String?                @map("account_name")
  status          PaidAdsConnectionStatus @default(disconnected)
  tokenRef        String?                @map("token_ref")
  refreshTokenRef String?                @map("refresh_token_ref")
  lastSyncAt      DateTime?              @map("last_sync_at")
  errorMessage    String?                @map("error_message")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  project PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("paid_ads_tiktok_connections")
}

model PaidAdsCampaign {
  id                 String               @id @default(uuid())
  userId             String               @map("user_id")
  projectId          String               @map("project_id")
  platform           PaidAdsPlatform      @default(google_ads)
  externalCampaignId String?              @map("external_campaign_id")
  tiktokAdGroupId    String?              @map("tiktok_ad_group_id")
  name               String
  status             PaidAdsCampaignStatus @default(draft)
  objectiveSummary   String?              @map("objective_summary")
  dailyBudgetMicros  BigInt?              @map("daily_budget_micros")
  geoTargets         Json                 @default("[]") @map("geo_targets")
  languageTargets    Json                 @default("[]") @map("language_targets")
  /** Optimizer: override por campanha para pausa por gasto USD (null = usar projecto/env). */
  optimizerPauseSpendUsd  Decimal?       @map("optimizer_pause_spend_usd") @db.Decimal(12, 4)
  /** Optimizer: override por campanha para mínimo de cliques (null = projecto/env). */
  optimizerPauseMinClicks Int?           @map("optimizer_pause_min_clicks")
  /** Flags do motor de optimização (ex.: recomendação de troca de criativo). */
  optimizerFlags     Json                 @default("{}") @map("optimizer_flags")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  project              PaidAdsProject              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adGroups             PaidAdsAdGroup[]
  metaAdsets           PaidAdsMetaAdset[]
  optimizerDecisions   PaidAdsOptimizerDecision[]

  @@index([projectId])
  @@map("paid_ads_campaigns")
}

/** Decisões do «Cérebro» V0 — auditoria de pausa, escala orçamento e flags (sem UI obrigatória). */
model PaidAdsOptimizerDecision {
  id              String          @id @default(uuid())
  projectId       String          @map("project_id")
  campaignId      String          @map("campaign_id")
  platform        PaidAdsPlatform
  ruleCode        String          @map("rule_code")
  decisionType    String          @map("decision_type")
  dryRun          Boolean         @default(false) @map("dry_run")
  inputSnapshot   Json            @default("{}") @map("input_snapshot")
  executed        Boolean         @default(false)
  executionOk     Boolean?        @map("execution_ok")
  executionDetail String?         @map("execution_detail") @db.Text
  createdAt       DateTime        @default(now()) @map("created_at")

  project  PaidAdsProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  campaign PaidAdsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([campaignId])
  @@map("paid_ads_optimizer_decisions")
}

model PaidAdsAdGroup {
  id                String              @id @default(uuid())
  campaignId        String              @map("campaign_id")
  name              String
  status            PaidAdsEntityStatus @default(draft)
  externalAdGroupId String?             @map("external_ad_group_id")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  campaign PaidAdsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords PaidAdsKeyword[]
  adsRsa   PaidAdsRsa[]

  @@index([campaignId])
  @@map("paid_ads_ad_groups")
}

model PaidAdsKeyword {
  id                  String            @id @default(uuid())
  adGroupId           String            @map("ad_group_id")
  text                String
  matchType           PaidAdsMatchType  @default(phrase) @map("match_type")
  status              PaidAdsEntityStatus @default(draft)
  externalCriterionId String?           @map("external_criterion_id")
  createdAt           DateTime          @default(now()) @map("created_at")

  adGroup PaidAdsAdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@map("paid_ads_keywords")
}

model PaidAdsRsa {
  id           String            @id @default(uuid())
  adGroupId    String            @map("ad_group_id")
  headlines    Json              @default("[]")
  descriptions Json              @default("[]")
  finalUrls    Json              @default("[]") @map("final_urls")
  status       PaidAdsEntityStatus @default(draft)
  externalAdId String?           @map("external_ad_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  adGroup PaidAdsAdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@map("paid_ads_rsa")
}

model PaidAdsChangeRequest {
  id            String                    @id @default(uuid())
  userId        String                    @map("user_id")
  projectId     String                    @map("project_id")
  type          PaidAdsChangeRequestType
  payload       Json                      @default("{}")
  status        PaidAdsChangeRequestStatus @default(pending)
  requestedById String                  @map("requested_by")
  reviewedById  String?                 @map("reviewed_by")
  reviewedAt    DateTime?             @map("reviewed_at")
  appliedAt     DateTime?               @map("applied_at")
  errorMessage  String?                 @map("error_message")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  project     PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User          @relation("PaidChangeRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy  User?         @relation("PaidChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@map("paid_ads_change_requests")
}

model PaidAdsGuardrails {
  id                         String   @id @default(uuid())
  projectId                  String   @unique @map("project_id")
  maxDailyBudgetMicros       BigInt   @default(50000000) @map("max_daily_budget_micros")
  maxMonthlySpendMicros      BigInt   @default(1500000000) @map("max_monthly_spend_micros")
  maxCpcMicros               BigInt?  @map("max_cpc_micros")
  allowedCountries           String[] @default([]) @map("allowed_countries")
  blockedKeywords            String[] @default([]) @map("blocked_keywords")
  requireApprovalAboveMicros BigInt?  @map("require_approval_above_micros")
  /**
   * Optimizer: pausa automática sem conversões quando o gasto na rede (janela configurável) ≥ este valor USD.
   * null = usar apenas `PAID_OPTIMIZER_PAUSE_SPEND_USD` / predefinição do servidor.
   */
  optimizerPauseSpendUsd     Decimal? @map("optimizer_pause_spend_usd") @db.Decimal(12, 4)
  /** Optimizer: mínimo de cliques no período para disparar a pausa; null = `PAID_OPTIMIZER_PAUSE_MIN_CLICKS` ou 5. */
  optimizerPauseMinClicks    Int?     @map("optimizer_pause_min_clicks")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  project PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("paid_ads_guardrails")
}

model PaidAdsAiRun {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  projectId        String            @map("project_id")
  feature          PaidAdsAiFeature
  model            String
  promptVersion    String            @default("v1") @map("prompt_version")
  inputSummary     String?           @map("input_summary")
  outputSummary    String?           @map("output_summary")
  tokensIn         Int?              @map("tokens_in")
  tokensOut        Int?              @map("tokens_out")
  estimatedCostUsd Decimal?          @map("estimated_cost_usd") @db.Decimal(10, 6)
  status           PaidAdsAiRunStatus @default(pending)
  errorMessage     String?           @map("error_message")
  createdById      String?           @map("created_by")
  createdAt        DateTime          @default(now()) @map("created_at")

  project   PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("PaidAdsAiRunAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("paid_ads_ai_runs")
}

model PaidAdsMetaAdset {
  id               String            @id @default(uuid())
  campaignId      String            @map("campaign_id")
  externalId      String?           @map("external_id")
  name            String
  status          PaidAdsEntityStatus @default(draft)
  dailyBudgetCents BigInt?          @map("daily_budget_cents")
  optimizationGoal String?         @map("optimization_goal")
  targeting        Json              @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  campaign  PaidAdsCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatives PaidAdsMetaCreative[]
  metaAds   PaidAdsMetaAd[]

  @@index([campaignId])
  @@map("paid_ads_meta_adsets")
}

model PaidAdsMetaCreative {
  id             String            @id @default(uuid())
  adsetId        String            @map("adset_id")
  externalId     String?           @map("external_id")
  primaryText    String            @map("primary_text")
  headline       String
  description    String?
  cta            PaidAdsMetaCta   @default(learn_more)
  destinationUrl String            @map("destination_url")
  imageAssetRef  String?          @map("image_asset_ref")
  placements     Json              @default("[]")
  status         PaidAdsEntityStatus @default(draft)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  adset PaidAdsMetaAdset @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  ads   PaidAdsMetaAd[]

  @@index([adsetId])
  @@map("paid_ads_meta_creatives")
}

model PaidAdsMetaAd {
  id           String            @id @default(uuid())
  adsetId      String            @map("adset_id")
  creativeId   String            @map("creative_id")
  name         String
  status       PaidAdsEntityStatus @default(draft)
  externalAdId String?          @map("external_ad_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  adset    PaidAdsMetaAdset    @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  creative PaidAdsMetaCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([adsetId])
  @@map("paid_ads_meta_ads")
}

model PaidAdsMetaInsight {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  level        String
  externalId   String   @map("external_id")
  date         DateTime @db.Date
  impressions  BigInt   @default(0)
  clicks       BigInt   @default(0)
  spendCents   BigInt   @default(0) @map("spend_cents")
  conversions  BigInt   @default(0)
  ctr          Decimal  @default(0) @db.Decimal(8, 4)
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  project PaidAdsProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, level, externalId, date])
  @@index([projectId, date(sort: Desc)])
  @@map("paid_ads_meta_insights")
}
