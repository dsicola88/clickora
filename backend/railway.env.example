# Edita railway.env no editor — NÃO colas estas linhas no terminal; no zsh, texto com ( ) pode dar "no matches found".
#
# Substitui o valor abaixo pela URL pública do Postgres na Railway, menu Connect, host tipo *.proxy.rlwy.net .
# Não uses postgres.railway.internal a partir do teu Mac.
# Se falhar a ligação, acaba a URL com ?sslmode=require

DATABASE_URL=""

# Opcional (Railway): URL pública só para `prisma migrate deploy` no contentor, se DATABASE_URL interno der P1001.
# DATABASE_URL_MIGRATE="postgresql://...@....proxy.rlwy.net:5432/railway?sslmode=require"
