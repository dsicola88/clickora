generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  owner
  admin
  member
  viewer
}

enum ProjectPaidMode {
  copilot
  autopilot
}

enum ConnectionStatus {
  disconnected
  connected
  error
}

enum PaidPlatform {
  google_ads
  meta_ads
  tiktok_ads
}

enum CampaignStatus {
  draft
  pending_publish
  live
  paused
  archived
  error
}

enum EntityStatus {
  draft
  pending_publish
  live
  paused
  archived
  error
}

enum MatchType {
  exact
  phrase
  broad
}

enum ChangeRequestType {
  create_campaign
  update_budget
  add_keywords
  publish_rsa
  pause_entity
  meta_create_campaign
  meta_update_budget
  meta_publish_creative
  meta_pause_entity
  tiktok_create_campaign
  tiktok_update_budget
  tiktok_pause_entity
}

enum ChangeRequestStatus {
  pending
  approved
  rejected
  applied
  failed
}

enum AiFeature {
  keyword_plan
  rsa_generation
  campaign_plan
}

enum AiRunStatus {
  pending
  success
  error
}

enum MetaCta {
  learn_more
  shop_now
  sign_up
  contact_us
  book_now
  download
  get_quote
  subscribe
}

/// Origem de pagamentos comerciais (ex.: fila Hotmart).
enum CommerceSource {
  hotmart
  other
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  /// Só contas e-mail+senha; contas "só Google" têm null.
  passwordHash String?  @map("password_hash")
  /// `sub` do OpenID Connect (Google) — início de sessão com Google.
  googleSub    String?  @unique @map("google_sub")
  fullName     String?  @map("full_name")
  /// Acesso ao painel comercial. Complemente com `PLATFORM_ADMIN_EMAILS` no ambiente.
  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizationsCreated Organization[]       @relation("OrgCreator")
  organizationMembers  OrganizationMember[]
  changeRequestsRequested PaidChangeRequest[] @relation("ChangeRequestedBy")
  changeRequestsReviewed  PaidChangeRequest[] @relation("ChangeReviewedBy")
  aiRunsCreated           AiRun[]
  organizationInvitesCreated OrganizationInvite[] @relation("OrganizationInviteCreatedBy")
  organizationInvitesUsed     OrganizationInvite[]  @relation("OrganizationInviteUsedBy")
  commercePayments         CommercePayment[]
  landingPagesEdited      LandingPage[]            @relation("LandingPageEditor")
}

/// Eventos de compra / assinatura (webhook Hotmart, etc.). E-mail de comprador para cruzar com contas.
model CommercePayment {
  id          String         @id @default(uuid()) @db.Uuid
  source      CommerceSource @default(hotmart)
  /// Id. da transação no gateway (idempotência quando preenchido).
  externalId  String?        @unique @map("external_id")
  eventType   String         @map("event_type")
  buyerEmail  String?        @map("buyer_email")
  productName String?        @map("product_name")
  productId   String?        @map("product_id")
  priceCents  Int?           @map("price_cents")
  currency    String         @default("BRL")
  status      String?
  appUserId   String?        @map("app_user_id") @db.Uuid
  rawPayload  Json?          @map("raw_payload")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  appUser User? @relation(fields: [appUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([buyerEmail])
  @@map("commerce_payments")
}

/// Landing pública (page builder); pertence a uma organização (tenant). Slug único globalmente para o URL /l/:slug.
model LandingPage {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  slug            String   @unique
  name            String
  isPublished     Boolean  @default(false) @map("is_published")
  document        Json     @default("{}")
  theme           Json?    @map("theme")
  updatedById     String?  @map("updated_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy    User?        @relation("LandingPageEditor", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([isPublished, slug])
  @@map("landing_pages")
}

/// Workspace B2B: um tenant; dados paid isolados por `organizationId` (membros em OrganizationMember).
model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("OrgCreator", fields: [createdById], references: [id])

  members              OrganizationMember[]
  invites              OrganizationInvite[]
  projects             Project[]
  googleAdsConnections GoogleAdsConnection[]
  metaConnections      MetaConnection[]
  tiktokConnections    TikTokConnection[]
  paidCampaigns        PaidCampaign[]
  paidChangeRequests   PaidChangeRequest[]
  aiRuns               AiRun[]
  landingPages         LandingPage[]
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           AppRole  @default(member)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

/// Convite com link; uso único. Opcional: restringe ao e-mail.
model OrganizationInvite {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  role           AppRole   @default(member)
  token          String    @unique
  expiresAt      DateTime  @map("expires_at")
  createdById    String    @map("created_by_id") @db.Uuid
  usedAt         DateTime? @map("used_at")
  usedByUserId   String?   @map("used_by_user_id") @db.Uuid
  emailConstraint String?  @map("email_constraint")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("OrganizationInviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy       User?        @relation("OrganizationInviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([token])
  @@map("organization_invites")
}

model Project {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  name           String
  websiteUrl     String?           @map("website_url")
  paidMode       ProjectPaidMode   @default(copilot) @map("paid_mode")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  googleAdsConnection  GoogleAdsConnection?
  metaConnection       MetaConnection?
  tiktokConnection     TikTokConnection?
  paidCampaigns        PaidCampaign[]
  paidGuardrails       PaidGuardrails?
  paidChangeRequests   PaidChangeRequest[]
  aiRuns               AiRun[]
  metaInsights         MetaInsight[]

  @@index([organizationId])
  @@map("projects")
}

model GoogleAdsConnection {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @map("organization_id") @db.Uuid
  projectId        String             @unique @map("project_id") @db.Uuid
  googleCustomerId String?            @map("google_customer_id")
  accountName      String?            @map("account_name")
  status           ConnectionStatus   @default(disconnected)
  tokenRef         String?            @map("token_ref")
  lastSyncAt       DateTime?          @map("last_sync_at")
  errorMessage     String?            @map("error_message")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("google_ads_connections")
}

model MetaConnection {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  projectId      String             @unique @map("project_id") @db.Uuid
  adAccountId    String?            @map("ad_account_id")
  businessId     String?            @map("business_id")
  accountName    String?            @map("account_name")
  status         ConnectionStatus   @default(disconnected)
  tokenRef       String?            @map("token_ref")
  lastSyncAt     DateTime?          @map("last_sync_at")
  errorMessage   String?            @map("error_message")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("meta_connections")
}

model TikTokConnection {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  projectId       String           @unique @map("project_id") @db.Uuid
  advertiserId    String?          @map("advertiser_id")
  accountName     String?          @map("account_name")
  status          ConnectionStatus @default(disconnected)
  tokenRef        String?          @map("token_ref")
  refreshTokenRef String?          @map("refresh_token_ref")
  lastSyncAt      DateTime?        @map("last_sync_at")
  errorMessage    String?          @map("error_message")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tiktok_connections")
}

model PaidCampaign {
  id                  String           @id @default(uuid()) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  projectId           String           @map("project_id") @db.Uuid
  platform            PaidPlatform     @default(google_ads)
  externalCampaignId  String?          @map("external_campaign_id")
  /// ID do ad group TikTok (API Marketing), se criado
  tiktokAdGroupId     String?          @map("tiktok_ad_group_id")
  name                String
  status              CampaignStatus   @default(draft)
  objectiveSummary    String?          @map("objective_summary")
  dailyBudgetMicros   BigInt?          @map("daily_budget_micros")
  geoTargets          Json             @default("[]") @map("geo_targets")
  languageTargets     Json             @default("[]") @map("language_targets")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adGroups     PaidAdGroup[]
  metaAdsets   MetaAdset[]

  @@index([projectId])
  @@map("paid_campaigns")
}

model PaidAdGroup {
  id                 String         @id @default(uuid()) @db.Uuid
  campaignId       String         @map("campaign_id") @db.Uuid
  name               String
  status             EntityStatus   @default(draft)
  externalAdGroupId  String?       @map("external_ad_group_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  campaign  PaidCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords  PaidKeyword[]
  adsRsa    PaidAdsRsa[]

  @@index([campaignId])
  @@map("paid_ad_groups")
}

model PaidKeyword {
  id                   String       @id @default(uuid()) @db.Uuid
  adGroupId            String       @map("ad_group_id") @db.Uuid
  text                 String
  matchType            MatchType    @default(phrase) @map("match_type")
  status               EntityStatus @default(draft)
  externalCriterionId  String?      @map("external_criterion_id")
  createdAt            DateTime     @default(now()) @map("created_at")

  adGroup PaidAdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@map("paid_keywords")
}

model PaidAdsRsa {
  id            String       @id @default(uuid()) @db.Uuid
  adGroupId     String       @map("ad_group_id") @db.Uuid
  headlines     Json         @default("[]")
  descriptions  Json         @default("[]")
  finalUrls     Json         @default("[]") @map("final_urls")
  status        EntityStatus @default(draft)
  externalAdId  String?      @map("external_ad_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  adGroup PaidAdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@index([adGroupId])
  @@map("paid_ads_rsa")
}

model PaidChangeRequest {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  projectId      String                @map("project_id") @db.Uuid
  type           ChangeRequestType
  payload        Json                  @default("{}")
  status         ChangeRequestStatus   @default(pending)
  requestedById  String                @map("requested_by") @db.Uuid
  reviewedById   String?               @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?             @map("reviewed_at")
  appliedAt      DateTime?             @map("applied_at")
  errorMessage   String?               @map("error_message")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("ChangeRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy   User?        @relation("ChangeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@map("paid_change_requests")
}

model PaidGuardrails {
  id                         String   @id @default(uuid()) @db.Uuid
  projectId                  String   @unique @map("project_id") @db.Uuid
  maxDailyBudgetMicros       BigInt   @default(50000000) @map("max_daily_budget_micros")
  maxMonthlySpendMicros      BigInt   @default(1500000000) @map("max_monthly_spend_micros")
  maxCpcMicros               BigInt?  @map("max_cpc_micros")
  allowedCountries           String[] @default(["BR", "PT", "US"]) @map("allowed_countries")
  blockedKeywords            String[] @default([]) @map("blocked_keywords")
  requireApprovalAboveMicros BigInt?  @map("require_approval_above_micros")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("paid_guardrails")
}

model AiRun {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  projectId         String        @map("project_id") @db.Uuid
  feature           AiFeature
  model             String
  promptVersion     String        @default("v1") @map("prompt_version")
  inputSummary      String?       @map("input_summary")
  outputSummary     String?       @map("output_summary")
  tokensIn          Int?          @map("tokens_in")
  tokensOut         Int?          @map("tokens_out")
  estimatedCostUsd  Decimal?      @map("estimated_cost_usd") @db.Decimal(10, 6)
  status            AiRunStatus   @default(pending)
  errorMessage      String?       @map("error_message")
  createdById       String?       @map("created_by") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("ai_runs")
}

model MetaAdset {
  id                String         @id @default(uuid()) @db.Uuid
  campaignId        String         @map("campaign_id") @db.Uuid
  externalId        String?        @map("external_id")
  name              String
  status            EntityStatus   @default(draft)
  dailyBudgetCents  BigInt?        @map("daily_budget_cents")
  optimizationGoal  String?        @map("optimization_goal")
  targeting         Json           @default("{}")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  campaign  PaidCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatives MetaCreative[]
  metaAds   MetaAd[]

  @@index([campaignId])
  @@map("meta_adsets")
}

model MetaCreative {
  id             String       @id @default(uuid()) @db.Uuid
  adsetId        String       @map("adset_id") @db.Uuid
  externalId     String?      @map("external_id")
  primaryText    String       @map("primary_text")
  headline       String
  description    String?
  cta            MetaCta      @default(learn_more)
  destinationUrl String       @map("destination_url")
  imageAssetRef  String?      @map("image_asset_ref")
  placements     Json         @default("[]")
  status         EntityStatus @default(draft)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  adset MetaAdset @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  ads   MetaAd[]

  @@index([adsetId])
  @@map("meta_creatives")
}

model MetaAd {
  id           String       @id @default(uuid()) @db.Uuid
  adsetId      String       @map("adset_id") @db.Uuid
  creativeId   String       @map("creative_id") @db.Uuid
  name         String
  status       EntityStatus @default(draft)
  externalAdId String?      @map("external_ad_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  adset    MetaAdset    @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  creative MetaCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([adsetId])
  @@map("meta_ads")
}

model MetaInsight {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  level        String
  externalId   String   @map("external_id")
  date         DateTime @db.Date
  impressions  BigInt   @default(0)
  clicks       BigInt   @default(0)
  spendCents   BigInt   @default(0) @map("spend_cents")
  conversions  BigInt   @default(0)
  ctr          Decimal  @default(0) @db.Decimal(8, 4)
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, level, externalId, date])
  @@index([projectId, date(sort: Desc)])
  @@map("meta_insights")
}
