# Raiz do pacote dpilotoaut — referência; anúncios em produção no dclickora usam o monólito (/api/paid), não este pacote.
# Copiar para `.env` (ver também frontend/vite.config.mts).

# --- Servidor / Prisma (já documentados no README do dpilotoaut) ---
# DATABASE_URL=
# AUTH_SECRET=

# URL do app Clickora (validação postMessage SSO + fallback).
# Produção: https://www.dclickora.com
VITE_CLICKORA_APP_URL="http://localhost:8080"

# Legado: SSO iframe → API Clickora (endpoint removido no monólito). Só serve se ainda correres o dpilotoaut isolado.
# CLICKORA_DPILOT_SSO_SECRET=""

# Cabeçalho CSP frame-ancestors (lista separada por espaços). Opcional; o vite.config.mts já inclui dclickora.com e localhost.
# DPILOTO_FRAME_ANCESTORS="'self' https://www.dclickora.com https://preview-xyz.vercel.app"
