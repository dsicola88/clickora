{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev --config frontend/vite.config.mts",
    "build": "vite build --config frontend/vite.config.mts",
    "build:dev": "vite build --config frontend/vite.config.mts --mode development",
    "preview": "vite preview --config frontend/vite.config.mts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:migrate:deploy": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema backend/prisma/schema.prisma",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:init-local": "bash scripts/init-local-pg.sh",
    "start": "node frontend/.output/server/index.mjs",
    "build:production": "npx prisma generate --schema backend/prisma/schema.prisma && npm run build",
    "verify:predeploy": "npm run db:generate && npm run db:migrate:deploy && npm run build",
    "test:vercel:build": "sh -c 'VERCEL=1 npm run build'",
    "test:local:prod": "npm run verify:predeploy",
    "playwright:install": "playwright install chromium",
    "test:landing-viewport": "node scripts/landing-viewport-smoke.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "prisma": {
    "seed": "tsx backend/prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.12",
