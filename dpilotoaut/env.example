# Copie para .env e preencha (nunca comite o .env real).

# —— Obrigatório em produção ——
# NÃO deixe o texto literal "USER" no URL de ligação.
#
# Dev sem Docker: cliente psql + Postgres em 5432 → npm run db:init-local
#   depois use (por defeito no projecto):
#   DATABASE_URL=postgresql://dpiloto:dpiloto@127.0.0.1:5432/paid_autopilot
#
# Dev com Docker (na pasta do projecto: docker compose up -d; porta 5434 no host — evita 5432/5433 ocupadas)
#   DATABASE_URL=postgresql://dpiloto:dpiloto@127.0.0.1:5434/paid_autopilot
DATABASE_URL=postgresql://dpiloto:dpiloto@127.0.0.1:5432/paid_autopilot
AUTH_SECRET=gerar_string_aleatoria_minimo_16_caracteres

# —— Teste alinhado com produção (local) ——
# Com Postgres a correr: npm run test:local:prod  (ver deploy/TESTE-LOCAL-PROD.txt)
#
# —— Produção (Railway / Vercel) ——
# Esquema: `npm run db:migrate:deploy` (já no deploy; ver deploy/NOTAS.txt).
# DATABASE_URL com SSL (Railway Postgres fornece URL pronta).
# VITE_APP_PUBLIC_URL=https://seu-dominio.vercel.app  (ou domínio Railway, se expuser o front aí)
# Reveja redirects OAuth (Google/Meta/TikTok) com o domínio final.

# —— Opcional: URLs e integrações ——
# VITE_APP_PUBLIC_URL=https://seu-dominio.com

# Google Ads (OAuth + API — developer token no Google Ads / Cloud)
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=   # (ou use DEVELOPER_TOKEN=)
# DEVELOPER_TOKEN=               # alternativa ao nome acima
# GOOGLE_OAUTH_REDIRECT_URL=https://seu-dominio.com/hooks/google-oauth/callback

# Meta (Facebook / Instagram Ads)
# META_APP_ID=
# META_APP_SECRET=
# META_OAUTH_REDIRECT_URL=https://seu-dominio.com/hooks/meta-oauth/callback

# TikTok Marketing API
# TIKTOK_APP_ID=
# TIKTOK_APP_SECRET=
# TIKTOK_OAUTH_REDIRECT_URL=https://seu-dominio.com/hooks/tiktok-oauth/callback
# TIKTOK_OAUTH_AUTH_BASE=https://ads.tiktok.com/marketing_api/auth

# Jobs / sync
# CRON_SECRET=

# IA (opcional)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Uploads locais
# UPLOAD_DIR=
