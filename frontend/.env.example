# Local: URL completa. Produção Vercel (defeito): deixa VITE_API_URL vazio — pedidos a /api (proxy vercel.json → Railway).
# Se o proxy der 502 em rotas pesadas: na Vercel define VITE_API_URL=https://SEU_SERVICO.up.railway.app/api
# e VITE_API_DIRECT_RAILWAY=true. Na Railway (API): FRONTEND_URL / CORS_ALLOWED_ORIGINS com https://www.dclickora.com e https://dclickora.com
# VITE_API_DIRECT_RAILWAY=true
# VITE_API_URL="https://clickora-production.up.railway.app/api"
VITE_API_URL="http://localhost:3001/api"
# Opcional: origem do site (https://dclickora.com) para exemplos no guia de rastreamento
# VITE_PUBLIC_APP_URL="https://dclickora.com"
# Login com Google — Client ID OAuth (tipo Web); autorizar http://localhost:8080 e http://localhost:5173 em URIs JavaScript
# VITE_GOOGLE_CLIENT_ID=""
