# Copiar para .env local. Na Vercel, definir em Project → Settings → Environment Variables.

# URL da API com sufixo /api (preferido; exposto ao cliente no build)
# VITE_PUBLIC_API_URL="https://SEU_SERVICO.up.railway.app/api"

# Legado — só se VITE_PUBLIC_API_URL estiver vazio
# VITE_API_URL="http://localhost:3001/api"

# Desenvolvimento local: deixa ambos vazios para usar http://localhost:3001/api no código

# Opcional: origem do site para textos de exemplo
# VITE_PUBLIC_APP_URL="https://dclickora.com"

# Origem canónica do site (OG, JSON-LD, links). Alinhar com `public/sitemap.xml` em produção.
# VITE_PUBLIC_SITE_ORIGIN="https://www.dclickora.com"

# Login Google — mesmo Client ID que GOOGLE_OAUTH_CLIENT_ID na API
# VITE_GOOGLE_CLIENT_ID=""

# Documentos legais no site (privacidade / rodapés)
# VITE_PUBLIC_SUPPORT_EMAIL="suporte@seudominio.com"
# VITE_PUBLIC_LEGAL_ENTITY_NAME="A sua empresa Lda."

# /tracking/dpilot — anúncios no mesmo app (API /api/paid). Ver docs/PAID-ADS-ARCHITECTURE.md
