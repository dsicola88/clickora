# URL da API (com /api). Em produção: https://dclickora.com/api (ou o URL que servir a API; build com este valor).
# Incluir sempre o protocolo (https://...) — ex.: https://xxx.up.railway.app/api
VITE_API_URL="http://localhost:3001/api"
# Opcional: origem do site (https://dclickora.com) para exemplos no guia de rastreamento
# VITE_PUBLIC_APP_URL="https://dclickora.com"
# Login com Google — Client ID OAuth (tipo Web); autorizar http://localhost:8080 e http://localhost:5173 em URIs JavaScript
# VITE_GOOGLE_CLIENT_ID=""
